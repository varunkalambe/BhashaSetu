# ===================================================================
# BhashaSetu — environment configuration
# Copy to .env and fill in / adjust as needed.
# ===================================================================

# ----- Database -----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/bhashasetu

# ----- Server -----
PORT=7860
NODE_ENV=production

# ----- Python interpreter paths -----
# Point these at the venv/conda env where requirements.txt is installed.
PYTHON_PATH=C:\Users\varun\miniconda3\envs\bhashasetu-mfa\python.exe
WAV2LIP_PYTHON_PATH=C:\Users\varun\miniconda3\envs\bhashasetu-mfa\python.exe
VOICECLONE_PYTHON_PATH=D:\Desktop Final\BhashaSetu major project\BhashaSetu\backend\bhashasetu_env\Scripts\python.exe

# ----- Feature flags (both OFF by default — the pipeline runs the fast
#        Whisper-only / no-lip-sync path unless you explicitly enable these) -----
# Set to 'true' to run real Kaldi/MFA forced alignment on the translated TTS
# audio instead of reusing Whisper word timestamps. Adds ~15-40s/clip on CPU.
# Requires backend/scripts/setup_mfa_models.sh to have been run first.
ENABLE_MFA_ALIGNMENT=false

# Set to 'true' to run Wav2Lip lip-sync generation on the final assembled
# video. This is the single biggest time cost in the full pipeline
# (2-5 min/30s clip on CPU). Requires Wav2Lip checkpoint — see WAV2LIP_PATH.
ENABLE_LIP_SYNC=false

# ----- MFA (only read if ENABLE_MFA_ALIGNMENT=true) -----
# Override the default '<language>_mfa' naming convention if you're using
# custom-trained acoustic models/dictionaries instead of the public ones.
# MFA_ACOUSTIC_MODEL=hindi_mfa
# MFA_DICTIONARY=hindi_mfa
MFA_PYTHON_PATH=mfa

# ----- Wav2Lip (only read if ENABLE_LIP_SYNC=true) -----
WAV2LIP_PATH=./Wav2Lip
# Checkpoint must be downloaded manually from:
# https://huggingface.co/Nekochu/Wav2Lip/blob/main/wav2lip_gan.pth
# and placed at ${WAV2LIP_PATH}/checkpoints/wav2lip_gan.pth
# License: CC-BY-NC (non-commercial/research use only — see LICENSE-NOTES.md)

# ----- GPU offload bridge (optional speed accelerator — see
#        backend/scripts/colab_gpu_worker.py) -----
# If unset, unreachable, or the remote job errors, everything falls back to
# local CPU execution automatically. Never a hard dependency.
# GPU_OFFLOAD_URL=https://your-tunnel-subdomain.ngrok-free.app
GPU_OFFLOAD_HEALTH_TIMEOUT_MS=3000
GPU_OFFLOAD_JOB_TIMEOUT_MS=600000

# ----- IndicTrans2 translation -----
# Path to a LoRA adapter trained with backend/scripts/train_lora_indictrans2.py.
# Leave unset to use the base IndicTrans2 checkpoint with no fine-tuning.
# INDICTRANS2_LORA_PATH=./uploads/lora_adapters/indictrans2-domain

# Minimum COMET-Kiwi / LaBSE quality-estimation score (0.0-1.0) before a
# translation is accepted without trying a higher-priority engine first.
# Below-threshold translations are still used as a safety net rather than
# discarded outright — see translationService.js.
INDICTRANS2_MIN_QE_SCORE=0.5

# ----- Audio mixing -----
# Volume multiplier (0.0-1.0) applied to the preserved Demucs background-music
# stem when it's mixed back under the dubbed voice track.
BGM_DUCK_VOLUME=0.35

# ----- Optional third-party translation fallbacks -----
# OPENAI_API_KEY=sk-...